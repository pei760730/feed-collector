# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# 部署模式:polling(開發 / 雲端常駐) 或 webhook
# 正式部署建議走 GitHub Actions cron drain(npm run drain),不靠常駐模式。
# 本機 Docker/WSL2 跑 polling 會撞 googleapis Premature close,要常駐請上雲端 VM。
BOT_MODE=polling
# 儲存:sheets(寫 Google,需憑證) 或 memory(乾跑,不寫真表,只需 token)
STORAGE=sheets
# webhook 模式才需要(對外可達網址):
WEBHOOK_DOMAIN=
WEBHOOK_PATH=/telegraf
PORT=8080

# ── Google Sheets ─────────────────────────────────────────────────────────
# 三選一(優先序:JSON 字串 > base64 > 檔案路徑):
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json

# OF 總表
GOOGLE_SHEET_ID=13BLYOdGeG9kWJZAFnTQFF0S9HPc_Lh9_Tjkmnbcfels
STAGING_SHEET_NAME=暫存區
# 總表(待拍池)分頁:OF-DOG 只讀此分頁的「影片連結」欄做去重。
PROD_SHEET_NAME=總表

# ── 行為 ──────────────────────────────────────────────────────────────────
# 來源白名單:只處理這些 chat/user id 的訊息(公開後防陌生人灌池),逗號分隔純數字。
# 私訊填你的 user id;群組收集填群 id(負數)。
# ★ STORAGE=sheets 時必填,沒填啟動就 fail-fast(寧可不跑也不大開)。memory 乾跑可留空。
ALLOWED_CHAT_IDS=
# 錯誤回報 chat（正式部署從 GitHub secret 注入）
ERROR_CHAT_ID=
# 短網址(vm./vt.tiktok、xhslink 等)是否自動跟隨 redirect 展開(會發網路請求;預設關)
EXPAND_SHORT_URLS=false

# ── 其他 ──────────────────────────────────────────────────────────────────
# 注:DATE 欄一律 Asia/Taipei(寫死於 utils/date.ts),無需設 TZ。
LOG_LEVEL=info
